<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1E2A22"/>
      <stop offset="100%" stop-color="#23272F"/>
    </linearGradient>
  </defs>
  <rect width="100" height="100" rx="20" fill="url(#bg)" stroke="#4F7A57" stroke-width="2"/>
  <!-- Medical cross -->
  <rect x="40" y="20" width="20" height="60" rx="4" fill="#C73A3A"/>
  <rect x="20" y="40" width="60" height="20" rx="4" fill="#C73A3A"/>
  <!-- Inner highlight -->
  <rect x="44" y="28" width="12" height="44" rx="2" fill="#D94A4A"/>
  <rect x="28" y="44" width="44" height="12" rx="2" fill="#D94A4A"/>
</svg>